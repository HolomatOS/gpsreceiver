<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_panel"
        android:padding="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/pairingCodeInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Pairing code"
            android:textColorHint="@color/text_dim"
            android:textColor="@color/text_primary"
            android:inputType="number"
            android:background="@android:color/transparent"
            android:padding="12dp"/>

        <Button
            android:id="@+id/trackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRACK"
            android:textColor="@color/bg_dark"
            android:backgroundTint="@color/cyan_accent"/>
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NOT CONNECTED"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        android:background="@color/bg_panel"
        android:padding="8dp"/>

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
